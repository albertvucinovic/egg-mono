# egg-mono environment variables
# Copy this file to .env and fill in your keys:
#   cp dot.env.example .env

# ── LLM Provider API Keys ───────────────────────────────────────
# Uncomment and fill in the providers you use.

#export OPENAI_API_KEY=sk-proj-...
#export GOOGLE_API_KEY=AI...
#export DEEPSEEK_API_KEY=sk-d...
#export GROQ_API_KEY=gsk_Q...
#export OPENROUTER_API_KEY=sk-or-v1-...
#export TOGETHERAI_API_KEY=...
#export DEEPINFRA_API_KEY=...
#export BASETEN_API_KEY=...
#export GROK_CODE_API_KEY=xai-...
#export MOONSHOTAI_API_KEY=sk-...
#export QWEN_CODE_API_KEY=...

# ── Local / Self-hosted LLM ─────────────────────────────────────
# For vLLM, llama.cpp, Ollama, etc.

#export LOCAL_API_KEY=token-abc123
#export API_BASE=http://localhost:10000/v1/chat/completions
#export API_MODEL=Qwen/QwQ-32B-AWQ

# ── Default Model Override ───────────────────────────────────────
# Overrides the default model from models.json at startup.

#export DEFAULT_MODEL="GPT 5 Nano"

# ── Web Search / Fetch Backends ─────────────────────────────────
# Defaults use EGG_WEB_BACKEND=auto:
# - web_search: Tavily Search first when TAVILY_API_KEY is set, then local
#   SearXNG as the no-key fallback.
# - fetch_url: Tavily Extract first when TAVILY_API_KEY is set, then direct HTTP
#   as the no-key fallback. Direct HTTP includes content-quality checks for
#   common blocked/challenge placeholder pages. No browser provider is active.

#export EGG_WEB_BACKEND=auto                # default; or pin globally: searxng, tavily
#export EGG_WEB_SEARCH_BACKEND=auto         # optional search-only override
#export EGG_WEB_FETCH_BACKEND=auto          # optional fetch-only override
#export SEARXNG_URL=http://localhost:8888   # local SearXNG search fallback
#export EGG_WEB_MAX_RESULTS=10              # default per web_search call (cap 25)
#export EGG_WEB_FETCH_TIMEOUT_SEC=20        # direct HTTP fetch timeout
#export EGG_WEB_FETCH_MAX_BYTES=2000000     # direct HTTP response byte limit
#export EGG_WEB_FETCH_MAX_CHARS=200000      # extracted fetch output character limit

# ── Tool API Keys ───────────────────────────────────────────────

# Enables hosted Tavily Search / Tavily Extract in auto mode, and is required
# when pinning EGG_WEB_BACKEND, EGG_WEB_SEARCH_BACKEND, or EGG_WEB_FETCH_BACKEND
# to tavily.
#export TAVILY_API_KEY=tvly-dev-...
