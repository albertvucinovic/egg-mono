#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

current_branch="$(git branch --show-current)"
if [[ "$current_branch" != "main" ]]; then
    echo "pre-push: skipping local test suite on branch $current_branch"
    exit 0
fi

echo "pre-push: running local test suite on main"
make test
